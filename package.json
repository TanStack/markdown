{
  "name": "@tanstack/markdown",
  "version": "0.0.9",
  "type": "module",
  "description": "A tiny, fast, deterministic Markdown renderer for blogs and documentation.",
  "license": "MIT",
  "packageManager": "pnpm@11.4.0",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./html": {
      "types": "./dist/html.d.ts",
      "import": "./dist/html.js"
    },
    "./parser": {
      "types": "./dist/parser.d.ts",
      "import": "./dist/parser.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./octane": {
      "types": "./dist/octane.d.ts",
      "import": "./dist/octane.js"
    },
    "./extensions/callouts": {
      "types": "./dist/extensions/callouts.d.ts",
      "import": "./dist/extensions/callouts.js"
    },
    "./extensions/comment-components": {
      "types": "./dist/extensions/comment-components.d.ts",
      "import": "./dist/extensions/comment-components.js"
    },
    "./extensions/docs": {
      "types": "./dist/extensions/docs.d.ts",
      "import": "./dist/extensions/docs.js"
    },
    "./extensions/framework": {
      "types": "./dist/extensions/framework.d.ts",
      "import": "./dist/extensions/framework.js"
    },
    "./extensions/headings": {
      "types": "./dist/extensions/headings.d.ts",
      "import": "./dist/extensions/headings.js"
    },
    "./extensions/tabs": {
      "types": "./dist/extensions/tabs.d.ts",
      "import": "./dist/extensions/tabs.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:corpus": "vitest run tests/corpus.test.tsx",
    "corpus:audit": "tsx scripts/audit-corpus.ts",
    "corpus:audit:tanstack": "tsx scripts/audit-tanstack-corpus.ts",
    "corpus:audit:external": "tsx scripts/audit-external-corpus.ts",
    "docs:verify": "node scripts/verify-docs.mjs",
    "conformance": "tsx scripts/conformance.ts",
    "bench": "tsx scripts/bench.ts",
    "size": "tsx scripts/measure-size.ts",
    "research": "pnpm run conformance && pnpm run size && pnpm run bench",
    "verify": "pnpm test && pnpm run typecheck && pnpm run build && pnpm run docs:verify && pnpm run research && pnpm pack --dry-run"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "octane": ">=0.1.12",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "octane": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "commonmark": "^0.31.2",
    "commonmark-spec": "0.31.2",
    "esbuild": "^0.25.0",
    "markdown-it": "^14.2.0",
    "markdown-wasm": "^1.2.0",
    "marked": "^18.0.5",
    "micromark": "^4.0.2",
    "octane": "0.1.12",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "unified": "^11.0.5",
    "vitest": "^3.2.0"
  }
}
